# Stripe — donations
# Secret key from https://dashboard.stripe.com/apikeys
# Use a test key (sk_test_...) in development and a live key (sk_live_...) in production.
# NEVER commit a real key. This file documents the shape only.
STRIPE_SECRET_KEY=sk_test_xxx

# Webhook signing secret for the /api/donate/webhook endpoint.
# Local: run `stripe listen --forward-to localhost:3000/api/donate/webhook`
#   and copy the whsec_... it prints.
# Production: create the endpoint in the Stripe dashboard (Developers > Webhooks)
#   and copy its signing secret.
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Public base URL, used to build Stripe success/cancel redirect URLs.
# Already consumed elsewhere in the app; defaults to https://b-59.com if unset.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
