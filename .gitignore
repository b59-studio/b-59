# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store

# Portable kit copied for other projects — not part of the live site
/portable-contract-signing/
*.pem

# Local scaffolding copied in by tooling — not part of the site
/templates/

# Internal / client-sensitive material that must NEVER land in this public repo.
# Migrated to the private repos (studio-portal: portal/contract docs + the seam
# receiving side; the-department: the boundary/projection/seam-plan docs). These
# ignore rules are kept as a guard so the material can never reappear here via an
# accidental `git add -A`.
/files.zip
/seam-implementation-plan.md
/src/lib/captures/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
